NODE_ENV=development
PORT=4177
DATABASE_URL=postgresql://taverna:taverna@localhost:5432/taverna_shlyapnika?schema=public
# Java backend can use DATABASE_URL directly. DATABASE_JDBC_URL is optional.
DATABASE_JDBC_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

TELEGRAM_BOT_TOKEN=
BOT_MODE=polling
WEBHOOK_URL=
INTERNAL_API_TOKEN=change-me-local-token
# Java backend protects /api/internal/** with BOT_BACKEND_SECRET first, then INTERNAL_API_TOKEN.
BOT_BACKEND_SECRET=change-me-local-token
JAVA_BACKEND_INTERNAL_URL=http://localhost:8080
BOT_POLLING_TIMEOUT_SECONDS=25
BOT_DISPLAY_NAME=Писарь Таверны
BOT_SHORT_DESCRIPTION=Создаёт афиши игр, ведёт галерею и помогает мастерам управлять рейтингом игроков.
BOT_CACHE_CHAT_ID=
BOT_CLEANUP_DELAY_SECONDS=86400
ADMIN_TELEGRAM_IDS=
ADMIN_TELEGRAM_USERNAMES=MisterHatter
AUTO_PUBLISH=true

SITE_BASE_URL=http://localhost:4177
SITE_ORIGINS=http://localhost:4177
CORS_ALLOWED_ORIGINS=http://localhost:4177
TAVERN_TIMEZONE=Europe/Minsk
PUBLIC_UPLOADS_URL=http://localhost:4177/uploads
FILE_STORAGE_DIR=uploads
MEDIA_STORAGE=local
SERVE_FRONTEND=false
FRONTEND_STATIC_DIR=static-site
TELEGRAM_COMMUNITY_URL=
PHONE_NUMBER=
UNP=
OPERATOR_NAME=
OPERATOR_ADDRESS=
PRIVACY_CONTACT=
CONSENT_WITHDRAWAL_CONTACT=
